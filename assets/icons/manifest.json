// ─── RECHERCHE GLOBALE ───
function searchGlobal(q) {
  const query = q.trim().toLowerCase();
  const resultsScreen = document.getElementById('search-results');
  const resultsList = document.getElementById('search-results-list');
  const bar2 = document.getElementById('search-bar-results');
  
  if (!query || query.length < 2) {
    resultsScreen.classList.remove('open');
    return;
  }
  
  resultsScreen.classList.add('open');
  if (bar2 && bar2.value !== q) bar2.value = q;
  
  const results = [];
  
  Object.entries(DATA).forEach(([key, mod]) => {
    if (!mod.cours) return;
    const cours = mod.cours;
    cours.forEach((chapitre, ci) => {
      // Search in chapter title
      if (chapitre.titre && chapitre.titre.toLowerCase().includes(query)) {
        results.push({
          module: mod.label || key,
          icon: mod.icon || '📚',
          color: mod.color || '#2D6A4F',
          title: chapitre.titre,
          excerpt: 'Chapitre ' + (ci+1),
          key, ci
        });
        return;
      }
      // Search in content
      if (chapitre.contenu) {
        chapitre.contenu.forEach(block => {
          if (block.text && block.text.toLowerCase().includes(query)) {
            const excerpt = block.text.length > 80 ? block.text.substring(0, 80) + '...' : block.text;
            results.push({
              module: mod.label || key,
              icon: mod.icon || '📚',
              color: mod.color || '#2D6A4F',
              title: chapitre.titre,
              excerpt,
              key, ci
            });
          }
        });
      }
    });
    // Search in fiches
    if (mod.fiches) {
      mod.fiches.forEach(f => {
        if ((f.t + ' ' + f.c).toLowerCase().includes(query)) {
          results.push({
            module: mod.label || key,
            icon: mod.icon || '📚',
            color: mod.color || '#2D6A4F',
            title: '📋 Fiche : ' + f.t,
            excerpt: f.c,
            key, ci: -1
          });
        }
      });
    }
  });
  
  // Deduplicate by title
  const seen = new Set();
  const unique = results.filter(r => {
    const k = r.key + r.title;
    if (seen.has(k)) return false;
    seen.add(k);
    return true;
  }).slice(0, 30);
  
  if (unique.length === 0) {
    resultsList.innerHTML = '<div style="text-align:center;padding:40px;color:#6B7280">Aucun résultat pour "' + q + '"</div>';
  } else {
    resultsList.innerHTML = unique.map(r => `
      <div class="search-result-item" onclick="goToResult('${r.key}', ${r.ci})">
        <div class="search-result-module" style="color:${r.color}">${r.icon} ${r.module}</div>
        <div class="search-result-title">${r.title}</div>
        <div class="search-result-excerpt">${r.excerpt}</div>
      </div>
    `).join('');
  }
}

function goToResult(key, chapIdx) {
  closeSearch();
  curKey = key;
  curCours = chapIdx >= 0 ? chapIdx : 0;
  curTab = chapIdx >= 0 ? 'cours' : 'fiches';
  showModule(key);
}

function closeSearch() {
  document.getElementById('search-results').classList.remove('open');
  const bar = document.getElementById('search-bar');
  if (bar) bar.value = '';
}

