function getSchema(name) {
  if (name === "AGCP") return svgAGCP();
  if (name === "TERRE") return svgTerre();
  if (name === "AMIANTE_LOC") return svgAmianteLOC();
  if (name === "AMIANTE_CONDUITS") return svgAmiante_CONDUITS();
  if (name === "PLOMB_ZONAGE") return svgPlombZonage();
  if (name === "TERMITES_TAB1") return svgTermitesTab1();
  if (name === "LICIEL_B1") return svgLicielB1();
  if (name === "LICIEL_B2") return svgLicielB2();
  if (name === "TEST_DIFF") return svgTestDiff();
  if (name === "CONTINUITE_LES") return svgContinuiteLES();
  if (name === "AMONT_AVAL") return svgAmontAval();
  if (name === "CONTINUITE_PRISE") return svgContinuitePrise();
  if (name === "IMPEDANCE_BOUCLE2") return svgImpedanceBoucle2();
  if (name === "CONTINUITE_LEP") return svgContinuiteLEP();
  if (name === "AUE") return svgAUE();
  if (name === "TEST_BOUCLE") return svgTestBoucle();
  if (name === "TEST_3PIQUETS") return svgTest3Piquets();
  if (name === "TERMITES_TAB2") return svgTermitesTab2();
  return "";
}

