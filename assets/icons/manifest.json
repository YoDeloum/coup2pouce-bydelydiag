function calcCertifTotal() {
  const ids = ['cd0','csol1','tutorat','cd1','csoa1','cd2','csoa2','cd3'];
  let total = 0;
  ids.forEach(id => {
    const el = document.getElementById('cf_frais_'+id);
    if (el && el.value) total += parseFloat(el.value) || 0;
  });
  const tot = document.getElementById('cf_total');
  if (tot) tot.textContent = total.toFixed(0) + ' €';
}

function saveCertifData() {
  const data = {};
  const allIds = ['date_debut','certificateur','cd0','csol1','tutorat','cd1','csoa1','cd2','csoa2','cd3',
                  'frais_cd0','frais_csol1','frais_tutorat','frais_cd1','frais_csoa1','frais_cd2','frais_csoa2','frais_cd3'];
  allIds.forEach(id => {
    const el = document.getElementById('cf_'+id);
    if (el) data[id] = el.value;
  });
  localStorage.setItem('certif_planning', JSON.stringify(data));
  calcCertifTotal();
  const btn = document.getElementById('certif_save_btn');
  btn.textContent = '✅ Sauvegardé !';
  btn.style.background = '#22C55E';
  setTimeout(() => { btn.textContent = '💾 Sauvegarder'; btn.style.background = '#6366F1'; }, 2000);
}

function loadCertifData() {
  try {
    const data = JSON.parse(localStorage.getItem('certif_planning') || '{}');
    const allIds = ['date_debut','certificateur','cd0','csol1','tutorat','cd1','csoa1','cd2','csoa2','cd3',
                    'frais_cd0','frais_csol1','frais_tutorat','frais_cd1','frais_csoa1','frais_cd2','frais_csoa2','frais_cd3'];
    allIds.forEach(id => {
      const el = document.getElementById('cf_'+id);
      if (el && data[id]) el.value = data[id];
    });
    calcCertifTotal();
    // Update total on frais input changes
    ['cd0','csol1','tutorat','cd1','csoa1','cd2','csoa2','cd3'].forEach(id => {
      const el = document.getElementById('cf_frais_'+id);
      if (el) el.addEventListener('input', calcCertifTotal);
    });
  } catch(e) {}
}

