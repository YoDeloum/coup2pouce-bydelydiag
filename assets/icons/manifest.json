<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Coup 2 Pouce — by DELY DIAG</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',system-ui,sans-serif;background:#fafaf8;color:#1A1D2E;min-height:100vh}
a{text-decoration:none}
/* HEADER */
#header{background:#fff;border-bottom:1px solid #E2E5F0;padding:0 20px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 1px 6px rgba(0,0,0,.07)}
.logo{font-size:22px;font-weight:800;letter-spacing:-0.5px}
.logo span{color:#E8650A;font-style:italic}
.logo-sub{font-size:9px;color:#6B7280;letter-spacing:2px;text-transform:uppercase;font-family:monospace}
/* CONTAINERS */
#home,#module{max-width:920px;margin:0 auto;padding:28px 16px}
#module{max-width:780px;display:none}
/* MODULE CARDS */
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(255px,1fr));gap:14px}
.mod-card{background:#fff;border:1px solid #E2E5F0;border-radius:14px;padding:20px 18px;cursor:pointer;transition:transform .2s,box-shadow .2s;position:relative;overflow:hidden}
.mod-card:hover{transform:translateY(-4px);box-shadow:0 8px 24px rgba(0,0,0,.1)}
.mod-icon{font-size:26px;margin-bottom:8px}
.mod-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:700;font-family:monospace;margin-bottom:4px}
.mod-title{font-weight:700;font-size:13px;margin-bottom:8px;line-height:1.3}
.tags{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:10px}
.tag{font-size:10px;padding:2px 8px;border-radius:999px;font-weight:600}
.start-hint{font-size:12px;color:#6B7280;font-weight:600}
/* PROGRESS */
.pbar-wrap{background:#E2E5F0;border-radius:999px;overflow:hidden}
.pbar-fill{height:100%;border-radius:999px;transition:width .5s}
/* TABS */
#tabs{display:flex;gap:4px;margin-bottom:18px;background:#fff;padding:4px;border-radius:11px;border:1px solid #E2E5F0}
.tab-btn{flex:1;padding:9px 6px;border-radius:8px;border:none;cursor:pointer;font-weight:600;font-size:13px;background:transparent;color:#6B7280;transition:all .2s;font-family:inherit}
.tab-btn.active{color:#fff}
/* COURS NAV */
.cours-item{padding:10px 13px;border-radius:8px;margin-bottom:3px;display:flex;align-items:center;gap:9px;cursor:pointer;border:1px solid transparent;transition:all .1s}
.cours-item:hover{background:rgba(0,0,0,.025)}
.cours-num{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
/* CARD */
.card{background:#fff;border:1px solid #E2E5F0;border-radius:13px;padding:22px 20px;box-shadow:0 2px 10px rgba(0,0,0,.04)}
.chap-badge{display:inline-block;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;color:#fff;margin-bottom:12px}
.cours-content{font-size:14px;line-height:1.85}
.cours-content p{margin-bottom:5px}
.cours-content .section-title{font-weight:700;margin-top:13px;margin-bottom:3px}
.cours-content strong{font-weight:700}
/* PHOTO ZONE */
.photo-zone{margin:18px 0;border:2px dashed #C8CBE0;border-radius:10px;padding:18px 16px;text-align:center;background:#F9FAFF}
.photo-zone .photo-icon{font-size:24px;margin-bottom:6px}
.photo-zone p{font-size:12px;color:#6B7280;font-weight:500}
/* NAV BUTTONS */
.nav-btns{display:flex;justify-content:space-between;margin-top:20px;padding-top:16px;border-top:1px solid #E2E5F0}
.btn{padding:10px 20px;border-radius:8px;border:none;cursor:pointer;font-weight:700;font-size:13px;font-family:inherit;transition:all .15s}
.btn-outline{background:transparent;border:1px solid #E2E5F0;color:#1A1D2E}
.btn-outline:hover{background:#fafaf8}
.btn-outline:disabled{color:#E2E5F0;cursor:default}
.btn-primary{color:#fff}
.btn-primary:hover{opacity:.9}

.opt-btn{display:block;width:100%;padding:11px 16px;border-radius:9px;border:1.5px solid #E2E5F0;background:#fff;cursor:pointer;font-size:13px;font-weight:500;text-align:left;margin-bottom:7px;font-family:inherit;transition:all .12s}
.opt-btn:hover:not(:disabled){border-color:#C8CBE0}
.opt-btn.correct{background:#F0FDF4;border-color:#22C55E;color:#15803D}
.opt-btn.wrong{background:#FEF2F2;border-color:#EF4444;color:#B91C1C}
.expl-box{border-radius:9px;padding:12px 16px;margin-top:10px;margin-bottom:12px;font-size:13px;line-height:1.7}
/* RESULT */
.result-box{text-align:center;padding:44px 16px}
.result-emoji{font-size:60px;margin-bottom:14px}
.result-score{font-size:36px;font-weight:800;margin-bottom:8px}
.result-msg{font-size:14px;font-weight:700;margin-bottom:24px}
.result-btns{display:flex;gap:10px;justify-content:center}
/* FICHES */
.fiches-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(185px,1fr));gap:10px;margin-bottom:18px}
.fiche{background:#fff;border:1px solid #E2E5F0;border-radius:11px;padding:13px;position:relative;overflow:hidden}
.fiche-bar{position:absolute;top:0;left:0;width:4px;height:100%;border-radius:2px 0 0 2px}
.fiche-label{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:7px;font-weight:600;font-family:monospace}
.fiche-val{font-size:13px;font-weight:700;line-height:1.4}
/* SVG SCHEMA */
.schema-wrap{margin-top:20px;background:#1E2235;border-radius:12px;padding:16px}
.schema-title{font-size:11px;font-family:monospace;letter-spacing:2px;text-transform:uppercase;margin-bottom:14px;text-align:center}
.schema-wrap svg{max-width:100%;display:block;margin:0 auto}
/* GLOBAL PROGRESS */
.global-prog{background:#fff;border:1px solid #E2E5F0;border-radius:12px;padding:14px 18px;margin-bottom:24px}
/* TIP BOX */
.tip-box{margin-top:24px;padding:14px 18px;background:#FFF9E6;border:1px solid #E8C54766;border-radius:12px;font-size:13px;line-height:1.7}
/* BACK BTN */
#back-btn{background:#fafaf8;border:1px solid #E2E5F0;cursor:pointer;width:30px;height:30px;border-radius:50%;font-size:14px;font-weight:700;display:none;margin-right:10px}

/* MATERIEL */
.mat-section{margin-bottom:28px}
.mat-section-title{font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;font-family:monospace;margin-bottom:12px;display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:8px}
.mat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px}
.mat-card{background:#fff;border:1px solid #E2E5F0;border-radius:12px;padding:16px;display:flex;flex-direction:column;gap:8px;transition:box-shadow .2s}
.mat-card:hover{box-shadow:0 4px 16px rgba(0,0,0,.1)}
.mat-card-top{display:flex;align-items:flex-start;gap:10px}
.mat-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.mat-name{font-weight:700;font-size:13px;line-height:1.3}
.mat-desc{font-size:12px;color:#6B7280;line-height:1.6;flex:1}
.mat-link{display:inline-flex;align-items:center;gap:6px;padding:8px 14px;border-radius:8px;font-size:12px;font-weight:700;text-decoration:none;color:#fff;margin-top:4px;transition:opacity .15s}
.mat-link:hover{opacity:.85}
.mat-link-amazon{background:#FF9900}
.mat-link-testoon{background:#0284C7}
/* CHATBOT */
@keyframes jeffrey-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}
@keyframes jeffrey-pulse {
  0%, 100% { transform: scale(1); opacity:1; }
  50% { transform: scale(1.3); opacity:0.7; }
}
#chat-btn{position:fixed;bottom:24px;right:24px;width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,#E8650A,#F59E0B);border:none;cursor:pointer;box-shadow:0 4px 16px rgba(232,101,10,.4);z-index:999;font-size:24px;display:flex;align-items:center;justify-content:center;transition:transform .2s}
#chat-btn:hover{transform:scale(1.1)}
#chat-panel{position:fixed;bottom:90px;right:16px;width:340px;max-width:95vw;height:500px;max-height:80vh;background:#fff;border-radius:16px;box-shadow:0 8px 32px rgba(0,0,0,.15);z-index:998;display:none;flex-direction:column;overflow:hidden;border:1px solid #E2E5F0}
#chat-panel.open{display:flex}
#chat-header{background:linear-gradient(135deg,#E8650A,#F59E0B);padding:14px 16px;display:flex;align-items:center;gap:10px;flex-shrink:0}
#chat-header .avatar{width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.25);display:flex;align-items:center;justify-content:center;font-size:18px}
#chat-header .info{flex:1}
#chat-header .name{color:#fff;font-weight:700;font-size:14px}
#chat-header .status{color:rgba(255,255,255,.8);font-size:11px}
#chat-header .close-btn{background:none;border:none;color:#fff;cursor:pointer;font-size:20px;padding:0;width:28px;height:28px;display:flex;align-items:center;justify-content:center;border-radius:50%;transition:background .15s}
#chat-header .close-btn:hover{background:rgba(255,255,255,.2)}
#chat-messages{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px;background:#F9FAFF}
.msg{max-width:85%;padding:10px 14px;border-radius:12px;font-size:13px;line-height:1.6}
.msg.bot{background:#fff;border:1px solid #E2E5F0;border-radius:4px 12px 12px 12px;align-self:flex-start;color:#1A1D2E}
.msg.user{background:linear-gradient(135deg,#E8650A,#F59E0B);color:#fff;border-radius:12px 4px 12px 12px;align-self:flex-end}
.msg.loading{background:#fff;border:1px solid #E2E5F0;color:#6B7280;font-style:italic}
#chat-input-wrap{padding:12px;border-top:1px solid #E2E5F0;display:flex;gap:8px;flex-shrink:0;background:#fff}
#chat-input{flex:1;padding:10px 14px;border-radius:20px;border:1.5px solid #E2E5F0;font-size:13px;font-family:inherit;outline:none;resize:none;height:40px;line-height:1.4;transition:border-color .15s}
#chat-input:focus{border-color:#E8650A}
