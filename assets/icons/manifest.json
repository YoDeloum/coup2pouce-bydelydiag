let selectedMods = [];
let checkStates = {};

function openChecklist() {
  document.getElementById('checklist-screen').classList.add('open');
}

function closeChecklist() {
  document.getElementById('checklist-screen').classList.remove('open');
}

function toggleMod(btn) {
  const mod = btn.dataset.mod;
  btn.classList.toggle('selected');
  if (selectedMods.includes(mod)) {
    selectedMods = selectedMods.filter(m => m !== mod);
  } else {
    selectedMods.push(mod);
  }
}

function generateChecklist() {
  if (selectedMods.length === 0) {
    alert('Sélectionne au moins un module !');
    return;
  }
  const container = document.getElementById('cl-results');
  container.innerHTML = '';
  
  selectedMods.forEach(mod => {
    const data = CHECKLIST_DATA[mod];
    if (!data) return;
    if (!checkStates[mod]) checkStates[mod] = {};
    
    const checked = Object.values(checkStates[mod]).filter(Boolean).length;
    const total = data.items.length;
    const pct = Math.round(checked/total*100);
    
    const section = document.createElement('div');
    section.className = 'cl-section';
    section.innerHTML = `
      <div class="cl-section-title" style="color:${data.color}">${data.icon} ${data.label}</div>
      <div class="cl-progress"><div class="cl-progress-fill" id="prog-${mod}" style="width:${pct}%"></div></div>
      <div style="font-size:11px;color:#6B7280;margin-bottom:10px;text-align:right">${checked}/${total} effectués</div>
      <div id="items-${mod}"></div>
      <button class="cl-reset-btn" onclick="resetMod('${mod}')">🔄 Réinitialiser ${data.label}</button>
    `;
    container.appendChild(section);
    
    const itemsContainer = document.getElementById('items-' + mod);
    data.items.forEach((item, i) => {
      const isChecked = checkStates[mod][i] || false;
      const div = document.createElement('div');
      div.className = 'cl-item';
      div.onclick = () => toggleCheck(mod, i, data.items.length);
      div.innerHTML = `
        <div class="cl-checkbox ${isChecked ? 'checked' : ''}" id="cb-${mod}-${i}"></div>
        <div class="cl-item-text ${isChecked ? 'checked' : ''}" id="ct-${mod}-${i}">${item}</div>
      `;
      itemsContainer.appendChild(div);
    });
  });
}

function toggleCheck(mod, idx, total) {
  if (!checkStates[mod]) checkStates[mod] = {};
  checkStates[mod][idx] = !checkStates[mod][idx];
  const isChecked = checkStates[mod][idx];
  
  document.getElementById('cb-' + mod + '-' + idx).className = 'cl-checkbox' + (isChecked ? ' checked' : '');
  document.getElementById('ct-' + mod + '-' + idx).className = 'cl-item-text' + (isChecked ? ' checked' : '');
  
  const checked = Object.values(checkStates[mod]).filter(Boolean).length;
  const pct = Math.round(checked/total*100);
  document.getElementById('prog-' + mod).style.width = pct + '%';
  
  // Update counter
  const section = document.getElementById('prog-' + mod).closest('.cl-section');
  section.querySelector('div[style*="text-align:right"]').textContent = checked + '/' + total + ' effectués';
}

function resetMod(mod) {
  checkStates[mod] = {};
  generateChecklist();
}


function handleCameraPhoto(input) {
  if (input.files && input.files[0]) {
    // Photo taken - it's saved to device gallery automatically
    const file = input.files[0];
    alert('📷 Photo prise : ' + file.name + '\nElle a été sauvegardée dans votre galerie.');
    input.value = '';
  }
}

