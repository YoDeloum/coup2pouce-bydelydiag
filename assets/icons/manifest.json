// ─────────────────────────────────────────────
function renderContenu(contenu, color) {
  return contenu.map(block => {
    if (block.type === "h") return `<p class="section-title" style="color:${color}">${block.text}</p>`;
    if (block.type === "photo") {
      if (block.text === "📸 Zone réservée ventilation") return '';
      return '<div class="photo-zone"><div class="photo-icon">📸</div><p>' + block.text + '</p></div>';
    }
    return `<p>${block.text}</p>`;
  }).join("");
}

