// ─── AGENDA ───
function addToCalendar() {
  const date = document.getElementById('m-date')?.value;
  const nom = document.getElementById('m-nom')?.value || '';
  const prenom = document.getElementById('m-prenom')?.value || '';
  const adresse = document.getElementById('m-adresse')?.value || '';
  const typeBien = document.getElementById('m-typeBien')?.value || '';
  
  if (!date) { alert('Saisis d\'abord une date de mission !'); return; }
  
  // Create calendar event URL (ICS format via data URI)
  const title = encodeURIComponent('Mission DELY DIAG — ' + nom + ' ' + prenom);
  const details = encodeURIComponent('Diagnostic ' + typeBien + '\nAdresse : ' + adresse);
  const dateStr = date.replace(/-/g, '');
  
  // Try to open native calendar via URL scheme
  const icsContent = [
    'BEGIN:VCALENDAR',
    'VERSION:2.0',
    'BEGIN:VEVENT',
    'DTSTART:' + dateStr + 'T090000',
    'DTEND:' + dateStr + 'T110000',
    'SUMMARY:Mission DELY DIAG — ' + nom + ' ' + prenom,
    'DESCRIPTION:Diagnostic ' + typeBien + ' — ' + adresse,
    'LOCATION:' + adresse,
    'END:VEVENT',
    'END:VCALENDAR'
  ].join('\n');
  
  const blob = new Blob([icsContent], {type: 'text/calendar'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'mission_delydiag.ics';
  a.click();
  URL.revokeObjectURL(url);
}

// ─── RAPPEL MISSION ───
function setMissionRappel() {
  const date = document.getElementById('m-date')?.value;
  if (!date) { alert('Saisis d\'abord une date de mission !'); return; }
  
  if (!('Notification' in window)) {
    alert('Les notifications ne sont pas disponibles sur ce navigateur.');
    return;
  }
  
  Notification.requestPermission().then(perm => {
    if (perm === 'granted') {
      const missionDate = new Date(date + 'T08:00:00');
      const now = new Date();
      const delay = missionDate - now - (24 * 60 * 60 * 1000); // Veille à 8h
      
      if (delay > 0) {
        setTimeout(() => {
          new Notification('📋 Mission DELY DIAG demain !', {
            body: 'N\'oubliez pas votre mission de diagnostic demain.',
            icon: '/icon-192.png'
          });
        }, delay);
        alert('✅ Rappel programmé la veille de la mission à 8h !');
      } else {
        alert('⚠️ La date est déjà passée ou trop proche pour programmer un rappel.');
      }
    } else {
      alert('Notifications refusées. Active-les dans les paramètres du navigateur.');
    }
  });
}

