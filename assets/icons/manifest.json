<script>
// ─────────────────────────────────────────────
// DONNÉES
// ─────────────────────────────────────────────
const DATA = {
  DPE:{
    driveUrl:"https://drive.google.com/open?id=1JP6i6E02zZTlAMAtbJNSaHoQxt0oLK07&usp=drive_fs",
    color:"#E8650A",icon:"🌡️",label:"DPE",full:"Diagnostic de Performance Énergétique",
    activeSousDossier:"sans_mention",
    cours:[
      {titre:"Généralités — Méthode et étiquettes",sd:"both",contenu:[
        {type:"h",text:"Méthode obligatoire : 3CL-DPE 2021"},
        {type:"p",text:"Depuis le 1er juillet 2021, le DPE est opposable. La méthode sur factures a été supprimée pour le résidentiel. Validité : 10 ans sauf travaux significatifs."},
        {type:"h",text:"Étiquette Énergie (kWh/m²/an)"},
        {type:"p",text:"A : ≤ 70 | B : 71-110 | C : 111-180 | D : 181-250 | E : 251-330 | F : 331-420 | G : > 420"},
        {type:"h",text:"Double seuil"},
        {type:"p",text:"La classe finale retient la moins bonne des deux étiquettes (Énergie et GES)."},
        {type:"h",text:"Passoires thermiques"},
        {type:"p",text:"• G interdits à la location dès 2025 | F dès 2028 | E dès 2034"},
      ]},
      {titre:"Les Murs",sd:"both",contenu:[
        {type:"p",text:"Les murs représentent une part importante des déperditions thermiques. Le diagnostiqueur doit identifier la composition de chaque paroi verticale extérieure."},
        {type:"h",text:"Informations à collecter"},
        {type:"p",text:"• Nature du matériau : brique, parpaing, pierre, béton, ossature bois..."},
        {type:"p",text:"• Épaisseur de la paroi (en cm)"},
        {type:"p",text:"• Présence d'une isolation : intérieure (ITI), extérieure (ITE) ou répartie"},
        {type:"p",text:"• Épaisseur et nature de l'isolant si visible ou connu"},
        {type:"h",text:"Points d'attention terrain"},
        {type:"p",text:"• Repérer les doublages intérieurs (plaques de plâtre avec isolation derrière)"},
        {type:"p",text:"• En cas de doute sur la composition, utiliser la valeur par défaut 3CL"},
        {type:"p",text:"• Photographier les murs représentatifs pour justifier les choix"},
        {type:"h",text:"⚠️ Murs donnant sur un Local Non Chauffé (LNC) — Calcul du coefficient b (AUE)"},
        {type:"p",text:"Lorsqu'un mur ne donne pas directement sur l'extérieur mais sur un local non chauffé (garage, cave, couloir commun...), on applique un coefficient b dit 'petit b' ou AUE."},
        {type:"p",text:"Ce coefficient b = SEXT / (SEXT + SCH) où :"},
        {type:"p",text:"• SEXT (Surface Froide) = parois du LNC donnant sur l'extérieur ou sur un terre plein"},
        {type:"p",text:"• SCH (Surface Chaude) = parois du LNC donnant sur un local chauffé"},
        {type:"p",text:"• Une paroi séparant deux LNC s'annule — ne pas la compter"},
        {type:"p",text:"• Une paroi donnant sur un terre plein est considérée comme froide"},
      ]},
      {titre:"AUE — Calcul du coefficient b (petit b)",sd:"sans_mention",schema:"AUE",contenu:[
        {type:"p",text:"Le coefficient b (AUE = Aménagement sous Utilisation Exclusive) s'applique aux parois séparant un local chauffé d'un local non chauffé (LNC)."},
        {type:"h",text:"Principe"},
        {type:"p",text:"b = SEXT / (SEXT + SCH)"},
        {type:"p",text:"Plus le LNC est exposé au froid (grandes surfaces froides), plus b est proche de 1 (se comporte comme un mur extérieur)."},
        {type:"p",text:"Plus le LNC est entouré de locaux chauffés, plus b est proche de 0 (peu de déperditions)."},
        {type:"h",text:"Exemple — Appartement au dernier étage"},
        {type:"p",text:"Le LNC (combles non aménagés) a :"},
        {type:"p",text:"• SEXT : mur Nord + mur Est + plafond du dernier étage (donnent sur l'extérieur)"},
        {type:"p",text:"• SCH : mur 1 (séparant LNC du LC du dessus) + mur 2 (séparant LNC du LC voisin)"},
        {type:"p",text:"• La paroi entre deux LNC → ne compte pas (s'annule)"},
        {type:"h",text:"Règles importantes"},
        {type:"p",text:"• Paroi donnant sur terre plein → toujours froide (SEXT)"},
        {type:"p",text:"• Paroi entre deux LNC → s'annule, ne pas compter"},
        {type:"p",text:"• Le logiciel DPE calcule b automatiquement si on renseigne correctement les surfaces"},
      ]},
      {titre:"Le Plafond",sd:"both",contenu:[
        {type:"p",text:"Le plafond est souvent la zone de déperdition la plus importante. Une bonne isolation en toiture peut faire gagner plusieurs classes énergétiques."},
        {type:"h",text:"Informations à collecter"},
        {type:"p",text:"• Type : combles perdus, combles aménagés, toiture terrasse, plancher haut sur local non chauffé"},
        {type:"p",text:"• Présence et nature de l'isolation : laine de verre, laine de roche, ouate, liège..."},
        {type:"p",text:"• Épaisseur de l'isolant (en cm)"},
        {type:"h",text:"Points d'attention terrain"},
        {type:"p",text:"• Monter dans les combles si accessibles pour vérifier l'isolation en place"},
        {type:"p",text:"• Vérifier que l'isolation couvre toute la surface sans zones manquantes"},
      ]},
      {titre:"Le Plancher",sd:"both",contenu:[
        {type:"p",text:"Le plancher bas (en contact avec le sol, un vide sanitaire ou un local non chauffé) génère des déperditions souvent sous-estimées."},
        {type:"h",text:"Informations à collecter"},
        {type:"p",text:"• Type : dalle béton sur terre-plein, vide sanitaire, sur local non chauffé (garage, cave)"},
        {type:"p",text:"• Présence d'une isolation sous le plancher"},
        {type:"p",text:"• Nature et épaisseur de l'isolant si connu"},
        {type:"h",text:"Points d'attention terrain"},
        {type:"p",text:"• Inspecter le vide sanitaire si accessible"},
        {type:"p",text:"• Un garage ou une cave en dessous = plancher sur local non chauffé à déclarer"},
      ]},
      {titre:"Les Fenêtres",sd:"both",contenu:[
        {type:"p",text:"Les fenêtres jouent sur les déperditions mais aussi sur les apports solaires. Elles doivent être renseignées avec précision."},
        {type:"h",text:"Informations à collecter"},
        {type:"p",text:"• Type de vitrage : simple (SV), double (DV), triple (TV)"},
        {type:"p",text:"• Nature du cadre : PVC, aluminium, bois, mixte"},
        {type:"p",text:"• Présence de volets : roulants, persiennes, battants"},
        {type:"p",text:"• Orientation de chaque menuiserie (N, S, E, O)"},
        {type:"p",text:"• Surface de chaque type de menuiserie"},
        {type:"h",text:"Points d'attention terrain"},
        {type:"p",text:"• Compter et mesurer chaque fenêtre ou regrouper les fenêtres identiques"},
        {type:"p",text:"• Ne pas oublier les velux et fenêtres de toit et leur inclinaison"},
      ]},
      {titre:"La Porte",sd:"both",contenu:[
        {type:"p",text:"Les portes donnant sur l'extérieur ou sur un local non chauffé contribuent aux déperditions et doivent être renseignées."},
        {type:"h",text:"Informations à collecter"},
        {type:"p",text:"• Nature : bois plein, bois creux, acier, PVC, vitrée..."},
        {type:"p",text:"• Destination : extérieur direct, garage, local non chauffé"},
        {type:"p",text:"• Présence d'un sas ou double sas"},
        {type:"h",text:"Points d'attention terrain"},
        {type:"p",text:"• Une porte entre logement et garage chauffé n'est pas une paroi froide"},
        {type:"p",text:"• Vérifier si la porte est isolée ou non (épaisseur, matière)"},
      ]},
      {titre:"Le Système de Chauffage",sd:"both",contenu:[
        {type:"p",text:"Le système de chauffage est l'un des postes les plus déterminants dans le calcul du DPE."},
        {type:"h",text:"Informations à collecter"},
        {type:"p",text:"• Énergie : gaz naturel, GPL, fioul, électricité, bois, PAC, réseau de chaleur..."},
        {type:"p",text:"• Générateur : chaudière, PAC (air/air, air/eau, eau/eau), poêle, insert, convecteur, radiateur électrique..."},
        {type:"p",text:"• Marque, modèle et année si visible sur la plaque signalétique"},
        {type:"p",text:"• Type d'émetteurs : radiateurs, plancher chauffant, ventilo-convecteurs"},
        {type:"h",text:"Points d'attention terrain"},
        {type:"p",text:"• Photographier la plaque signalétique de la chaudière / PAC"},
        {type:"p",text:"• Vérifier si le chauffage est individuel ou collectif"},
        {type:"p",text:"• Plusieurs systèmes (PAC + appoint électrique) → tous les déclarer"},
        {type:"p",text:"• Repérer la présence d'une régulation (thermostat, programmateur)"},
      ]},
      {titre:"Le Système ECS",sd:"both",contenu:[
        {type:"p",text:"L'eau chaude sanitaire représente en moyenne 10 à 15% de la consommation énergétique d'un logement."},
        {type:"h",text:"Informations à collecter"},
        {type:"p",text:"• Type : chauffe-eau électrique, thermodynamique, ballon couplé chaudière, production instantanée gaz, solaire..."},
        {type:"p",text:"• Volume du ballon (en litres) si présent"},
        {type:"p",text:"• Énergie utilisée + année si visible"},
        {type:"h",text:"Points d'attention terrain"},
        {type:"p",text:"• Un ballon électrique de plus de 15 ans est pénalisant pour le DPE"},
        {type:"p",text:"• Vérifier si l'ECS est individuelle ou collective"},
        {type:"p",text:"• Photographier la plaque signalétique du chauffe-eau"},
      ]},
      {titre:"La Ventilation",sd:"both",contenu:[
        {type:"p",text:"La ventilation conditionne la qualité de l'air intérieur et influe sur les déperditions thermiques."},
        {type:"h",text:"Types de ventilation"},
        {type:"p",text:"• Ventilation naturelle : grilles hautes et basses, ouvrants"},
        {type:"p",text:"• VMC simple flux : extraction mécanique dans les pièces humides"},
        {type:"p",text:"• VMC double flux : extraction + soufflage avec récupération de chaleur"},
        {type:"p",text:"• VMC Gaz : ventilation couplée aux appareils à gaz"},
        {type:"h",text:"Points d'attention terrain"},
        {type:"p",text:"• Vérifier les entrées d'air en pièces principales (salon, chambres)"},
        {type:"p",text:"• Vérifier les bouches d'extraction en pièces humides"},
        {type:"p",text:"• Sans ventilation identifiable = ventilation naturelle par défaut"},
        
      ]},
      {titre:"Les Ponts Thermiques",sd:"both",contenu:[
        {type:"p",text:"Les ponts thermiques sont des zones de faiblesse dans l'enveloppe du bâtiment où les déperditions sont localement plus importantes."},
        {type:"h",text:"Principaux ponts thermiques"},
        {type:"p",text:"• Jonction mur/plancher et mur/toiture"},
        {type:"p",text:"• Encadrements de fenêtres et portes"},
        {type:"p",text:"• Balcons traversants"},
        {type:"p",text:"• Piliers ou poteaux béton dans les murs isolés"},
        {type:"h",text:"Dans le logiciel DPE"},
        {type:"p",text:"En méthode 3CL, les ponts thermiques sont estimés via des coefficients forfaitaires. Pas besoin de les mesurer physiquement."},
        {type:"p",text:"Une isolation par l'extérieur (ITE) supprime quasi totalement les ponts thermiques de liaison."},
      ]},
      {titre:"Recommandations d'installation",sd:"both",contenu:[
        {type:"p",text:"Les recommandations d'installation proposent des travaux concrets pour améliorer la performance énergétique du logement. Elles font partie intégrante du DPE depuis 2021."},
        {type:"h",text:"Travaux types à proposer"},
        {type:"p",text:"• Isolation des murs (ITI ou ITE)"},
        {type:"p",text:"• Isolation de la toiture / combles"},
        {type:"p",text:"• Remplacement des menuiseries (SV → DV)"},
        {type:"p",text:"• Remplacement du système de chauffage (PAC, chaudière à condensation)"},
        {type:"p",text:"• Installation d'un chauffe-eau thermodynamique"},
        {type:"p",text:"• Mise en place d'une VMC"},
        {type:"h",text:"Important"},
        {type:"p",text:"Le logiciel génère automatiquement des scénarios. Les recommandations doivent être réalistes et adaptées au logement — pas de préconisations génériques non pertinentes."},
      ]},
      {titre:"Recommandations d'usage",sd:"both",contenu:[
        {type:"p",text:"Les recommandations d'usage sont des conseils comportementaux pour réduire la consommation sans travaux. Elles sont générées automatiquement par le logiciel DPE et sont opposables."},
        {type:"h",text:"Exemples typiques"},
        {type:"p",text:"• Régler la température à 19°C en pièces de vie, 17°C la nuit"},
        {type:"p",text:"• Ne pas obstruer les grilles de ventilation"},
        {type:"p",text:"• Purger régulièrement les radiateurs"},
        {type:"p",text:"• Fermer les volets la nuit en hiver"},
        {type:"p",text:"• Entretenir la chaudière et les filtres VMC annuellement"},
      ]},
      {titre:"Immeubles collectifs",sd:"mention",contenu:[
        {type:"p",text:"Le DPE Mention concerne les immeubles à partir de 3 logements, en monopropriété ou en copropriété."},
        {type:"h",text:"Types de bâtiments concernés"},
        {type:"p",text:"• Immeubles collectifs d'habitation (3 logements minimum)"},
        {type:"p",text:"• Monopropriétés (un seul propriétaire pour tout l'immeuble)"},
        {type:"p",text:"• Copropriétés"},
        {type:"h",text:"Spécificités importantes"},
        {type:"p",text:"• Plafond : il s'agit du DERNIER PLAFOND HAUT de l'immeuble (toiture ou combles)"},
        {type:"p",text:"• Plancher : il s'agit du PREMIER PLANCHER BAS (rez-de-chaussée)"},
        {type:"p",text:"• Les planchers entre étages chauffés = PLANCHERS INTERMÉDIAIRES → à renseigner uniquement dans les ponts thermiques, pas comme parois déperditives"},
        {type:"h",text:"Important"},
        {type:"p",text:"Les informations sur les caractéristiques du bâti et les appareils installés dans les parties communes sont des informations uniquement — elles n'entrent pas dans le calcul énergétique de chaque logement."},
      ]},
      {titre:"Méthodologie 3CL",sd:"mention",contenu:[
        {type:"p",text:"La méthode de calcul est la 3CL-DPE 2021 — identique au DPE résidentiel sans mention. Les informations à collecter sont les mêmes."},
        {type:"h",text:"Ce qu'on renseigne (identique au résidentiel)"},
        {type:"p",text:"• Murs extérieurs : nature, épaisseur, isolation (ITI/ITE/répartie)"},
        {type:"p",text:"• Fenêtres : type vitrage (SV/DV/TV), cadre, volets, orientation, surface"},
        {type:"p",text:"• Système de chauffage : énergie, type de générateur, émetteurs"},
        {type:"p",text:"• Système ECS : type de production, énergie, volume"},
        {type:"p",text:"• Ventilation : naturelle, VMC simple flux, double flux, VMC gaz"},
        {type:"h",text:"Différences vs DPE sans mention"},
        {type:"p",text:"• Pas de plancher bas entre logements → planchers intermédiaires = ponts thermiques"},
        {type:"p",text:"• Pas de plafond intermédiaire entre logements → uniquement le dernier plafond haut"},
        {type:"p",text:"• Les parties communes (couloirs, halls, cage d'escalier...) constituent un LNC qui s'étend du RDC jusqu'au dernier étage — elles sont à calculer sur la totalité du bâtiment, pas seulement à l'étage concerné"},
      ]},
      {titre:"Locaux commerciaux",sd:"mention",contenu:[
        {type:"p",text:"Pour les locaux commerciaux, la méthode est sur FACTURE. C'est la seule situation où la méthode sur factures est encore autorisée."},
        {type:"h",text:"Documents à collecter"},
        {type:"p",text:"• Factures d'énergie des 3 dernières années OU les 12 derniers mois"},
        {type:"p",text:"• Toutes les énergies : électricité, gaz, fioul, bois..."},
        {type:"p",text:"• Surface utile du local"},
        {type:"p",text:"• Type d'usage : commerce, bureau, hôtel, restaurant..."},
        {type:"h",text:"Rôle des informations sur le bâti"},
        {type:"p",text:"Toutes les informations recueillies sur les caractéristiques du bâtiment et les appareils installés sont uniquement des informations descriptives. Elles n'entrent pas dans le calcul — seules les factures servent de base au DPE."},
        {type:"h",text:"Points d'attention"},
        {type:"p",text:"• Exclure les années atypiques : COVID, travaux, fermeture, vacance"},
        {type:"p",text:"• Si les factures sont inexploitables ou inexistantes → le DPE sera VIERGE, faute de pouvoir effectuer un calcul de consommation via les factures"},
        {type:"p",text:"• Ce type de DPE nécessite la certification MENTION obligatoirement"},
      ]},
    ],
    fiches:[
      {t:"Validité",c:"10 ans (sauf si travaux de rénovation)"},
      {t:"Méthode résidentiel",c:"3CL-DPE 2021 (obligatoire)"},
      {t:"Méthode tertiaire",c:"Sur factures 3 ans (mention uniquement)"},
      {t:"Opposable",c:"Depuis le 1er juillet 2021"},
      {t:"Passoires G",c:"Interdits à la location dès 2025"},
      {t:"Passoires F",c:"Interdits à la location dès 2028"},
      {t:"Double seuil",c:"Classe = moins bonne des 2 étiquettes"},
      {t:"Murs",c:"Nature + épaisseur + isolation (ITI/ITE/répartie)"},
      {t:"Plafond",c:"Type combles + isolation + épaisseur"},
      {t:"Plancher",c:"Terre-plein / vide sanitaire / local non chauffé"},
      {t:"Fenêtres",c:"SV/DV/TV + cadre + volets + orientation + surface"},
      {t:"Chauffage",c:"Énergie + générateur + émetteurs + année"},
      {t:"ECS",c:"Type + énergie + volume + année"},
      {t:"Ventilation",c:"Naturelle / VMC SF / VMC DF / VMC Gaz"},
      {t:"Ponts thermiques",c:"Coefficients forfaitaires 3CL — pas de mesure physique"},
      {t:"Recommandations",c:"Installation (travaux) + Usage (comportement)"},
      {t:"DPE Mention — Immeuble collectif",c:"Dernier plafond haut + Premier plancher bas — Planchers intermédiaires = ponts thermiques"},
      {t:"Planchers intermédiaires",c:"Entre étages chauffés → ponts thermiques uniquement, pas de paroi déperditive"},
      {t:"DPE Mention — Local commercial",c:"Méthode sur factures (3 ans ou 12 mois) — bâti = info uniquement"},
      {t:"Coefficient b (AUE)",c:"b = SF / (SF + SCH) — paroi LNC → extérieur = SF / paroi LNC → LC = SCH"},
      {t:"Paroi entre 2 LNC",c:"S'annule — ne pas compter"},
      {t:"Paroi LNC → terrain",c:"Toujours froide (SF)"},
    ],
