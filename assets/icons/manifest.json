// ─── RECONNAISSANCE VOCALE ───
let recognition = null;
let isRecording = false;

function initVoice() {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRecognition) return null;
  const r = new SpeechRecognition();
  r.lang = 'fr-FR';
  r.continuous = true;
  r.interimResults = true;
  return r;
}

function startVoiceDescription(targetId, btnId) {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRecognition) {
    alert('La reconnaissance vocale n\'est pas disponible sur votre navigateur. Utilisez Chrome sur Android.');
    return;
  }
  
  const btn = document.getElementById(btnId);
  const target = document.getElementById(targetId);
  
  if (isRecording) {
    recognition.stop();
    isRecording = false;
    btn.className = 'vocal-btn idle';
    btn.innerHTML = '🎤 Dicter';
    return;
  }
  
  recognition = initVoice();
  recognition.onresult = (e) => {
    let transcript = '';
    for (let i = 0; i < e.results.length; i++) {
      transcript += e.results[i][0].transcript;
    }
    target.value = transcript;
  };
  recognition.onerror = () => {
    isRecording = false;
    btn.className = 'vocal-btn idle';
    btn.innerHTML = '🎤 Dicter';
  };
  recognition.onend = () => {
    isRecording = false;
    btn.className = 'vocal-btn idle';
    btn.innerHTML = '🎤 Dicter';
  };
  
  recognition.start();
  isRecording = true;
  btn.className = 'vocal-btn recording';
  btn.innerHTML = '⏹️ Stop';
}

// Checklist vocale
function startChecklistVoice(mod) {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRecognition) {
    alert('Reconnaissance vocale non disponible. Utilisez Chrome sur Android.');
    return;
  }
  
  const r = new SpeechRecognition();
  r.lang = 'fr-FR';
  r.continuous = false;
  r.interimResults = false;
  
  r.onresult = (e) => {
    const said = e.results[0][0].transcript.toLowerCase();
    const data = CHECKLIST_DATA[mod];
    if (!data) return;
    
    // Find matching item
    data.items.forEach((item, i) => {
      const itemLower = item.toLowerCase();
      const words = itemLower.split(' ').filter(w => w.length > 3);
      const match = words.some(w => said.includes(w));
      if (match && !checkStates[mod]?.[i]) {
        toggleCheck(mod, i, data.items.length);
        // Haptic feedback
        if (navigator.vibrate) navigator.vibrate(100);
      }
    });
  };
  r.start();
}

